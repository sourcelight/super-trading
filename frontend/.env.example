# Cognito OIDC (PKCE) — copy to .env.local and fill in.
VITE_COGNITO_AUTHORITY=https://cognito-idp.<region>.amazonaws.com/<userPoolId>
VITE_COGNITO_CLIENT_ID=<appClientId>
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/
# Optional Cognito Hosted UI domain for logout (e.g. https://<domain>.auth.<region>.amazoncognito.com)
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/

# Base path for API/WebSocket calls (defaults to same-origin "" — dev uses the Vite proxy).
VITE_API_BASE=

# --- Local simulation (no AWS) ---
# Set true to bypass Cognito entirely (pairs with the backend `local` profile, which
# permits all). The VITE_COGNITO_* values above can stay as placeholders in this mode.
VITE_AUTH_DISABLED=false
